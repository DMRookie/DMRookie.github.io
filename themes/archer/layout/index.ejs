<%_ if (is_home()) { _%>
    <%
        // ===== 首页分类配置（如需增删分类，改这里即可）=====
        const cateList = [
            { name: '语言大模型', desc: '大语言模型的概念原理、训练与工程化实践' },
            { name: '视觉大模型', desc: '多模态与视觉理解方向的前沿探索与综述' },
            { name: 'AI应用',     desc: 'AI 技术在真实业务场景中的落地实践' },
            { name: '投资理财',   desc: '周期、估值与人性，A 股投研学习笔记' },
        ];
        const PREVIEW_COUNT = 2; // 每个分类卡片预览的文章数量
        // 建立 分类名 -> 分类对象 的映射，用于取文章数、文章列表与链接
        const catMap = {};
        site.categories.each(function (c) { catMap[c.name] = c; });
    %>
    <style>
        .cate-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            grid-auto-rows: 1fr;
            align-items: stretch;
            gap: 1.25rem;
            max-width: 800px;
            margin: 1rem auto 2rem;
            padding: 0 .5rem;
        }
        /* 首页头像缩小并居中，降低 profile 整体高度，使其与右侧分类更协调 */
        .home-body .profile-avatar { width: 150px; margin: 0 auto; }
        /* 隐藏首页 footer 中与 profile 重复的联系方式 */
        .home-body .footer .social { display: none; }
        .cate-card {
            display: flex;
            flex-direction: column;
            min-width: 0;
            padding: 1.4rem 1.5rem 1.25rem;
            background: #ffffff;
            border: 1px solid #ebebea;
            border-radius: 14px;
            box-shadow: 0 1px 2px rgba(15, 15, 15, 0.03);
            transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease;
        }
        .cate-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 26px rgba(15, 15, 15, 0.10);
            border-color: #d8d8d6;
        }

        .cate-head {
            display: flex;
            align-items: center;
            text-decoration: none;
            color: inherit;
        }
        .cate-icon {
            flex: none;
            width: 42px; height: 42px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.45rem; border-radius: 11px;
            margin-right: .8rem;
            transition: transform .22s ease;
        }
        .cate-card:hover .cate-icon { transform: scale(1.08) rotate(-4deg); }
        .cate-card:nth-child(1) .cate-icon { background: #eef3ff; }
        .cate-card:nth-child(2) .cate-icon { background: #fdeef6; }
        .cate-card:nth-child(3) .cate-icon { background: #eefaf3; }
        .cate-card:nth-child(4) .cate-icon { background: #fff5e9; }

        .cate-name { font-size: 1.12rem; font-weight: 650; color: #37352f; }
        .cate-count {
            margin-left: auto;
            font-size: .72rem; color: #9b9a97;
            background: #f1f1ef; border-radius: 20px;
            padding: .12rem .55rem;
        }
        .cate-desc { margin: .85rem 0 .25rem; font-size: .82rem; line-height: 1.5; color: #9b9a97; }

        .cate-posts { list-style: none; margin: .5rem 0 0; padding: 0; }
        .cate-posts li { border-top: 1px solid #f0f0ef; }
        .cate-posts a {
            display: flex; align-items: baseline; gap: .6rem;
            padding: .55rem .15rem;
            text-decoration: none; color: #37352f;
            border-radius: 6px;
            transition: background .15s ease, color .15s ease;
        }
        .cate-posts a:hover { background: #f5f5f4; color: #2383e2; }
        .cp-title {
            flex: 1; min-width: 0;
            font-size: .88rem;
            overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
        }
        .cp-title::before { content: '·'; color: #c9c9c5; margin-right: .45rem; }
        .cp-date { flex: none; font-size: .72rem; color: #b6b5b2; font-variant-numeric: tabular-nums; }

        .cate-more {
            margin-top: .7rem; align-self: flex-start;
            font-size: .78rem; color: #9b9a97; text-decoration: none;
            transition: color .2s ease, transform .2s ease;
        }
        .cate-more:hover { color: #2383e2; transform: translateX(3px); }
        .cate-empty { margin: .9rem 0 .2rem; font-size: .82rem; color: #b6b5b2; }

        /* ===== 暗色模式（body.is-dark 由下方脚本依据 dark.css 是否加载来同步）===== */
        body.is-dark .cate-card { background: #2b2b2b; border-color: #3a3a3a; box-shadow: none; }
        body.is-dark .cate-card:hover { border-color: #4d4d4d; box-shadow: 0 10px 26px rgba(0, 0, 0, 0.45); }
        body.is-dark .cate-name { color: #eceae6; }
        body.is-dark .cate-count { background: #3a3a3a; color: #9b9a97; }
        body.is-dark .cate-desc { color: #8a8986; }
        body.is-dark .cate-posts li { border-top-color: #3a3a3a; }
        body.is-dark .cate-posts a { color: #d4d2cd; }
        body.is-dark .cate-posts a:hover { background: #363636; color: #5aa3ec; }
        body.is-dark .cp-date { color: #6f6e6b; }
        body.is-dark .cate-card:nth-child(1) .cate-icon { background: #2b3550; }
        body.is-dark .cate-card:nth-child(2) .cate-icon { background: #46293c; }
        body.is-dark .cate-card:nth-child(3) .cate-icon { background: #243d31; }
        body.is-dark .cate-card:nth-child(4) .cate-icon { background: #4a3a23; }

        @media (max-width: 600px) {
            .cate-grid { grid-template-columns: 1fr; grid-auto-rows: auto; gap: 1rem; margin: 1.5rem auto 2rem; }
        }
    </style>

    <main class="main index-page home-cate-page">
        <section class="cate-grid">
            <%_ cateList.forEach(function (item) { _%>
                <%_ const c = catMap[item.name]; _%>
                <%_ const count = c ? c.length : 0; _%>
                <%_ const path = c ? c.path : ('categories/' + item.name + '/'); _%>
                <%_ let posts = []; _%>
                <%_ if (c) { posts = c.posts.toArray().sort(function (a, b) { return b.date - a.date; }).slice(0, PREVIEW_COUNT); } _%>
                <div class="cate-card">
                    <a class="cate-head" href="<%- url_for(path) %>">
                        <span class="cate-icon">📁</span>
                        <span class="cate-name"><%= item.name %></span>
                        <span class="cate-count"><%= count %> 篇</span>
                    </a>
                    <p class="cate-desc"><%= item.desc %></p>
                    <%_ if (count > 0) { _%>
                        <ul class="cate-posts">
                            <%_ posts.forEach(function (p) { _%>
                                <li>
                                    <a href="<%- url_for(p.path) %>" title="<%= p.title %>">
                                        <span class="cp-title"><%= p.title || '[Untitled Post]' %></span>
                                        <span class="cp-date"><%- date(p.date, 'YYYY/MM/DD') %></span>
                                    </a>
                                </li>
                            <%_ }) _%>
                        </ul>
                        <%_ if (count > posts.length) { _%>
                            <a class="cate-more" href="<%- url_for(path) %>">查看全部 <%= count %> 篇 →</a>
                        <%_ } _%>
                    <%_ } else { _%>
                        <p class="cate-empty">敬请期待…</p>
                    <%_ } _%>
                </div>
            <%_ }) _%>
        </section>
    </main>

    <script>
        (function () {
            // dark.css 由主题在暗色模式下动态注入到 <head>，据此同步卡片暗色样式
            function syncDark() {
                if (!document.body) return;
                var dark = !!document.getElementById('stylesheet-theme-dark');
                document.body.classList.toggle('is-dark', dark);
            }
            syncDark();
            document.addEventListener('DOMContentLoaded', syncDark);
            new MutationObserver(syncDark).observe(document.documentElement, { childList: true, subtree: true });
        })();
    </script>
<%_ } else { _%>
    <main class="main index-page">
        <%_ page.posts.each(function (_post) { _%>
            <%_ const truncateLength = typeof theme.truncate_length === 'number' ? theme.truncate_length : 300 _%>
            <%_ let _content = undefined _%>
            <%_ let showReadMoreButton = false _%>
            <%_ if(!!_post.excerpt) { _%>
                <%_ _content = _post.excerpt _%>
                <%_ showReadMoreButton = true _%>
            <%_ } else if (!!_post.abstract) { _%>
                <%_ _content = _post.abstract _%>
                <%_ showReadMoreButton = true _%>
            <%_ } else { _%>
                <% _content = truncateLength === 0 ? null : truncate(strip_html(_post.content), {length: truncateLength, omission: '...'})%>
            <%_ } _%>
            <article class="index-post">
                <a class="abstract-title" href="<%- url_for(_post.path) %>">
                    <%_ if(_post.top || _post.sticky) { _%>
                        <span class="iconfont-archer stick-top">&#xe63d;</span>
                    <%_ } _%>
                    <span class="abstract-title-text"><%= _post.title || '[Untitled Post]' %></span>
                </a>
                <div class="abstract-content">
                    <%- _content %>
                </div>
                <!-- read more -->
                <%_ if(!!theme.read_more_button && !!showReadMoreButton) { _%>
                    <div class="abstract-read-more-button">
                        <a href="<%- url_for(_post.path) %>">
                            <span style="margin-right: 0.2rem;"><%- __('read_more') %></span>
                            <i class="fas fa-angle-right"></i>
                        </a>
                    </div>
                <%_ } _%>
                <div class="abstract-post-meta">
                    <!-- date -->
                    <div class="abstract-date" title="Last updated: <%- !!_post.updated ? date(_post.updated, "YYYY/MM/DD") : date(_post.date, "YYYY/MM/DD") %>">
                        <span class="abstract-calander iconfont-archer">&#xe676;</span><span class="abstract-time"><%- date(_post.date, "YYYY/MM/DD") %></span>
                    </div>
                    <!-- tags -->
                    <%_ if (_post.tags.length || (theme.show_categories && _post.categories.length)) { _%>
                        <%- partial('./_partial/base-title-tags', {
                            currPost: _post,
                            className: 'abstract-tags'
                        }) %>
                    <%_ } _%>
                </div>
            </article>
            <div class="index-post-divider"></div>
        <%_ }) _%>
        <!-- paginator  -->
        <%_ if (page.total > 1) { _%>
            <nav class="page-nav">
                <%- paginator({
                    prev_text: '< PREV',
                    next_text: 'NEXT >'
                }) %>
            </nav>
        <%_ } _%>
    </main>
<%_ } _%>
